{
  "name": "hellodk-blog",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "predev": "bash scripts/sync-public-assets.sh && node scripts/build-knowledge-index.mjs",
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev --port 4321 --host 127.0.0.1",
    "dev:layout-b": "bash scripts/sync-public-assets.sh && ASTRO_TELEMETRY_DISABLED=1 HOME_LAYOUT=feed astro dev --port 4325 --host 127.0.0.1",
    "dev:layout-c": "bash scripts/sync-public-assets.sh && ASTRO_TELEMETRY_DISABLED=1 HOME_LAYOUT=grid astro dev --port 4326 --host 127.0.0.1",
    "dev:layouts": "bash scripts/dev-layouts.sh",
    "prebuild": "bash scripts/sync-public-assets.sh && node scripts/build-knowledge-index.mjs",
    "build": "astro build && npx pagefind --site dist",
    "cf:deploy": "bash scripts/cf-deploy.sh",
    "preview": "astro preview",
    "preview:all": "ASTRO_TELEMETRY_DISABLED=1 ./scripts/preview-all.sh",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250614.0",
    "pagefind": "^1.5.2",
    "wrangler": "^4.22.0"
  }
}
