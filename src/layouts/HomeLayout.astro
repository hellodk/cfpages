---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import { site } from '../data/site';

interface Props {
  title?: string;
}
const { title = 'hellodk.io — DevOps, SRE & Homelab' } = Astro.props;
---

<BaseLayout title={title}>
  <!-- Hero — dark with cover image -->
  <div class="site-head" style={`background-image: url(${site.homeCover})`}>
    <div class="site-head__overlay"></div>
    <Nav overlay={true} />
    <div class="site-head__content">
      <a class="site-head__logo" href="/">hello<em>dk</em></a>
      <p class="site-head__quote">{site.name}</p>
      <h2 class="site-head__tagline">{site.description}</h2>
    </div>
  </div>

  <!-- Post list -->
  <main class="site-main">
    <div class="site-main__inner">
      <slot />
    </div>
  </main>

  <footer class="site-footer">
    <div class="site-footer__inner">
      <section class="copyright">
        <a href="/">hellodk.io</a> &copy; {new Date().getFullYear()}
      </section>
      <section class="poweredby">
        <a href="https://github.com/hellodk" target="_blank" rel="noopener">GitHub</a>
        &nbsp;·&nbsp;
        <a href="/newsletter">Newsletter</a>
        &nbsp;·&nbsp;
        <a href="/feed.xml">RSS</a>
        &nbsp;·&nbsp;
        <a href="/about">About</a>
      </section>
    </div>
  </footer>
</BaseLayout>

<style>
/* Hero */
.site-head {
  position: relative;
  background: #15171a center center no-repeat;
  background-size: cover;
  min-height: 60vh;
  display: flex;
  flex-direction: column;
}
.site-head__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.55);
}
.site-head__content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 48px 24px 56px;
  text-align: center;
}
.site-head__logo {
  font-family: var(--font-mono);
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 700;
  color: #fff;
  text-decoration: none;
  letter-spacing: -1px;
  margin-bottom: 12px;
}
.site-head__logo em { color: var(--color-accent); font-style: normal; }
.site-head__quote {
  font-family: var(--font-serif);
  font-size: clamp(1rem, 2.5vw, 1.35rem);
  font-weight: 300;
  font-style: italic;
  color: rgba(255,255,255,0.92);
  margin-bottom: 10px;
  letter-spacing: 0.2px;
}
.site-head__tagline {
  font-family: var(--font-sans);
  font-size: 0.875rem;
  font-weight: 400;
  color: rgba(255,255,255,0.6);
  letter-spacing: 0.5px;
  text-transform: uppercase;
}

/* Post list area */
.site-main {
  background: #fff;
  padding: 48px 0;
}
.site-main__inner {
  max-width: 700px;
  margin: 0 auto;
  padding: 0 24px;
}

/* Footer */
.site-footer {
  background: #15171a;
  border-top: 1px solid rgba(255,255,255,0.1);
  padding: 24px;
  text-align: center;
  font-family: var(--font-sans);
  font-size: 0.8rem;
}
.site-footer__inner {
  max-width: 1060px;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8px;
}
.site-footer a { color: rgba(255,255,255,0.5); text-decoration: none; }
.site-footer a:hover { color: #fff; }
.site-footer .copyright, .site-footer .poweredby { color: rgba(255,255,255,0.5); }
</style>
