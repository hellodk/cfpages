---
import ChirpingLayout from './ChirpingLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  tags: string[];
  cover?: string;
  readingTime?: number;
}

const { title, description, date, updated, tags, cover, readingTime } = Astro.props;
const formattedDate = date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
const crumb = title.length > 45 ? title.slice(0, 45) + '…' : title;
---

<ChirpingLayout
  title={`${title} — hellodk.io`}
  {description} {cover}
  type="article"
  variant="article"
  publishedDate={date}
  {tags}
  breadcrumb={crumb}
>
  <article class="post-art" data-pagefind-body>
    <header class="post-art__hd">
      <div class="post-art__tags">
        {tags.slice(0,4).map(t => <a href={`/tag/${t}`} class="post-art__tag">{t}</a>)}
      </div>
      <h1 class="post-art__title">{title}</h1>
      <div class="post-art__byline">
        <span>Deepak Gupta</span>
        <span class="s">·</span>
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {readingTime && <><span class="s">·</span><span>{readingTime} min read</span></>}
      </div>
      {cover && <img src={cover} alt={title} class="post-art__cover" />}
    </header>

    <div class="post-art__body">
      <slot />
    </div>

    <slot name="after-prose" />
  </article>
</ChirpingLayout>

<style>
.post-art { width: 100%; max-width: none; }

.post-art__hd { margin-bottom: 28px; padding-bottom: 20px; border-bottom: 1px solid #dee2e6; }

.post-art__tags { display: flex; gap: 6px; margin-bottom: 12px; flex-wrap: wrap; }
.post-art__tag { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: #0066cc; background: #e7f1ff; padding: 2px 8px; border-radius: 3px; text-decoration: none; }
.post-art__tag:hover { background: #0066cc; color: #fff; }

.post-art__title { font-size: clamp(1.4rem, 3vw, 1.9rem); font-weight: 700; line-height: 1.2; color: #1a1a1a; margin-bottom: 12px; letter-spacing: -0.3px; }

.post-art__byline { font-size: 0.8rem; color: #6c757d; display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.s { color: #dee2e6; }

.post-art__cover { width: 100%; max-height: 360px; object-fit: cover; border-radius: 8px; margin-top: 20px; display: block; }

/* Serif body */
.post-art__body { font-family: 'Merriweather', Georgia, serif; font-size: 1rem; line-height: 1.8; color: #212529; }
.post-art__body h2 { font-family: system-ui, sans-serif; font-size: 1.3rem; font-weight: 700; margin: 2rem 0 0.75rem; color: #1a1a1a; }
.post-art__body h3 { font-family: system-ui, sans-serif; font-size: 1.1rem; font-weight: 700; margin: 1.75rem 0 0.5rem; }
.post-art__body p { margin-bottom: 1.4rem; }
.post-art__body ul, .post-art__body ol { margin: 0 0 1.4rem 1.5rem; }
.post-art__body li { margin-bottom: 0.4rem; }
.post-art__body a { color: #0066cc; text-decoration: underline; }
.post-art__body blockquote { border-left: 3px solid #0066cc; padding: 0.5rem 1rem; margin: 1.5rem 0; color: #6c757d; font-style: italic; background: #f8f9fa; }
.post-art__body pre { margin: 1.5rem 0; border-radius: 6px; overflow-x: auto; }
.post-art__body code:not(pre code) { font-family: 'JetBrains Mono', monospace; font-size: 0.85em; background: #f1f3f5; color: #c0392b; border: 1px solid #dee2e6; padding: 0.1em 0.4em; border-radius: 3px; }
.post-art__body hr { border: none; border-top: 1px solid #dee2e6; margin: 2rem 0; }
</style>
