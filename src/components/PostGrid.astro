---
import PostCard from './PostCard.astro';
import type { PostSummary } from '../utils/toPost';

interface Props {
  posts: PostSummary[];
  featureFirst?: boolean;
}

const { posts, featureFirst = true } = Astro.props;
---

<section class="grid">
  {posts.map((post, i) => (
    <PostCard
      slug={post.slug}
      title={post.title}
      description={post.description}
      date={post.date}
      tags={post.tags}
      cover={post.cover}
      readingTime={post.readingTime}
      featured={featureFirst && i === 0}
    />
  ))}
</section>

<style>
.grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 28px;
  padding: 8px 0 32px;
}
@media (min-width: 900px) {
  .grid :global(.card--featured) {
    grid-column: span 2;
  }
}
@media (max-width: 600px) {
  .grid { grid-template-columns: 1fr; }
}
</style>
