---
import NavIcon from '../icons/NavIcon.astro';
import { mainNav, llmNav, isNavActive } from '../../data/navigation';

const currentPath = Astro.url.pathname;
---

<div class="lsb">
  <div class="lsb__brand">
    <a href="/" class="lsb__logo">hello<em>dk</em></a>
    <p class="lsb__tagline">DevOps · SRE · Homelab</p>
  </div>

  <nav class="lsb__nav" aria-label="Main">
    <h3 class="lsb__section-title">Menu</h3>
    <ul>
      {mainNav.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={['lsb__link', isNavActive(link.href, currentPath) && 'active']}
          >
            <span class="icon"><NavIcon name={link.icon} size={18} /></span>
            <span class="label">{link.label}</span>
          </a>
        </li>
      ))}
    </ul>

    <h3 class="lsb__section-title">LLM</h3>
    <ul>
      {llmNav.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={['lsb__link', isNavActive(link.href, currentPath) && 'active']}
          >
            <span class="icon"><NavIcon name={link.icon} size={18} /></span>
            <span class="label">{link.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="lsb__utilities">
    <a href="/search" class:list={['lsb__link', 'lsb__link--utility', isNavActive('/search', currentPath) && 'active']}>
      <span class="icon"><NavIcon name="search" size={18} /></span>
      <span class="label">Search</span>
    </a>
    <a href="/contact" class:list={['lsb__link', 'lsb__link--utility', isNavActive('/contact', currentPath) && 'active']}>
      <span class="icon"><NavIcon name="contact" size={18} /></span>
      <span class="label">Contact</span>
    </a>
  </div>

  <div class="lsb__social">
    <a href="https://github.com/hellodk" target="_blank" rel="noopener" aria-label="GitHub" class="soc">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
    </a>
    <a href="/feed.xml" aria-label="RSS" class="soc">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
    </a>
    <a href="/newsletter" aria-label="Newsletter" class="soc">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
    </a>
  </div>
</div>

<style>
.lsb { display: flex; flex-direction: column; height: 100%; }
.lsb__brand { padding: 20px 16px 12px; border-bottom: 1px solid #dee2e6; }
.lsb__logo { font-family: 'JetBrains Mono', monospace; font-size: 1.15rem; font-weight: 700; color: #1a1a1a; text-decoration: none; display: block; margin-bottom: 4px; }
.lsb__logo em { color: #e5645e; font-style: normal; }
.lsb__tagline { font-size: 0.7rem; color: #6c757d; }
.lsb__nav { flex: 1; padding: 4px 0 8px; overflow-y: auto; }
.lsb__section-title {
  margin: 12px 16px 6px;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #868e96;
}
.lsb__nav ul { list-style: none; padding: 0; margin: 0 0 4px; }
.lsb__link {
  display: flex; align-items: center; gap: 10px;
  padding: 8px 16px; color: #495057; text-decoration: none;
  font-size: 0.875rem; font-weight: 500;
  border-left: 3px solid transparent; transition: all 0.12s;
}
.lsb__link:hover { background: #e9ecef; color: #1a1a1a; }
.lsb__link.active { color: #0066cc; background: #e7f1ff; border-left-color: #0066cc; font-weight: 600; }
.lsb__utilities { border-top: 1px solid #dee2e6; padding: 4px 0; }
.lsb__link--utility { font-size: 0.82rem; }
.icon { display: flex; align-items: center; flex-shrink: 0; color: inherit; opacity: 0.85; }
.lsb__link.active .icon { opacity: 1; }
.lsb__social { display: flex; gap: 4px; padding: 12px 16px; border-top: 1px solid #dee2e6; margin-top: auto; }
.soc {
  display: flex; align-items: center; justify-content: center;
  width: 34px; height: 34px; border-radius: 6px;
  color: #6c757d; text-decoration: none; transition: all 0.12s;
  border: 1px solid transparent;
}
.soc:hover { background: #e9ecef; color: #1a1a1a; border-color: #dee2e6; }
@media (max-width: 1100px) {
  .lsb__tagline, .label, .lsb__section-title { display: none; }
  .lsb__logo { font-size: 0.65rem; text-align: center; }
  .lsb__link { padding: 10px; justify-content: center; gap: 0; }
  .lsb__social { justify-content: center; flex-wrap: wrap; padding: 8px 4px; }
  .soc { width: 28px; height: 28px; }
}
</style>
