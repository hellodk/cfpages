---
interface Props {
  posts: Array<{ slug: string; title: string; description: string; date: Date; tags: string[]; cover: string }>
}
const { posts } = Astro.props;
---

<div class="feed">
  {posts.map(p => {
    const d = p.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
    return (
      <article class="fi">
        <a href={`/${p.slug}`} class="fi__thumb-wrap">
          <img src={p.cover} alt={p.title} class="fi__thumb" loading="lazy" />
        </a>
        <div class="fi__body">
          <div class="fi__meta">
            <time datetime={p.date.toISOString()}>{d}</time>
            {p.tags.slice(0,2).map(t => <a href={`/tag/${t}`} class="fi__tag">{t}</a>)}
          </div>
          <h2 class="fi__title"><a href={`/${p.slug}`}>{p.title}</a></h2>
          <p class="fi__desc">{p.description}</p>
        </div>
      </article>
    );
  })}
</div>

<style>
.feed {}
.fi { display: flex; gap: 18px; padding: 20px 0; border-bottom: 1px solid #f1f3f5; align-items: stretch; }
.fi:last-child { border-bottom: none; }
.fi__thumb-wrap { flex-shrink: 0; display: block; border-radius: 8px; overflow: hidden; }
.fi__thumb { width: 168px; height: 112px; object-fit: cover; display: block; transition: transform 0.25s; }
.fi__thumb-wrap:hover .fi__thumb { transform: scale(1.04); }
.fi__body { flex: 1; min-width: 0; }
.fi__meta { display: flex; align-items: center; gap: 8px; margin-bottom: 5px; font-size: 0.72rem; color: #6c757d; flex-wrap: wrap; }
.fi__tag { color: #0066cc; font-size: 0.68rem; font-weight: 700; text-transform: uppercase; text-decoration: none; }
.fi__tag:hover { text-decoration: underline; }
.fi__title { font-size: 0.9rem; font-weight: 700; line-height: 1.35; margin-bottom: 5px; }
.fi__title a { color: #1a1a1a; text-decoration: none; }
.fi__title a:hover { color: #0066cc; }
.fi__desc { font-size: 0.78rem; color: #6c757d; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>
