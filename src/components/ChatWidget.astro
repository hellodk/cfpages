---
const enabled = import.meta.env.PUBLIC_CHAT_ENABLED !== 'false';
---

{enabled && (
  <div id="chat-widget" class="chat-widget" aria-live="polite">
    <button id="chat-toggle" class="chat-widget__toggle" aria-label="Open blog assistant" aria-expanded="false">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
    </button>
    <div id="chat-panel" class="chat-widget__panel" hidden>
      <header class="chat-widget__header">
        <strong>hellodk assistant</strong>
        <button id="chat-close" aria-label="Close">×</button>
      </header>
      <div id="chat-messages" class="chat-widget__messages">
        <p class="chat-widget__hint">Ask about DevOps, Kubernetes, or anything on this blog.</p>
      </div>
      <form id="chat-form" class="chat-widget__form">
        <input id="chat-input" type="text" placeholder="Ask a question…" maxlength="500" autocomplete="off" required />
        <button type="submit">Send</button>
      </form>
    </div>
  </div>
)}

<script is:inline>
  (function () {
    const toggle = document.getElementById('chat-toggle');
    const panel = document.getElementById('chat-panel');
    const closeBtn = document.getElementById('chat-close');
    const form = document.getElementById('chat-form');
    const input = document.getElementById('chat-input');
    const messages = document.getElementById('chat-messages');
    if (!toggle || !panel || !form || !input || !messages) return;

    let knowledgeIndex = null;

    function openChat() {
      panel.hidden = false;
      toggle.setAttribute('aria-expanded', 'true');
      input.focus();
    }
    function closeChat() {
      panel.hidden = true;
      toggle.setAttribute('aria-expanded', 'false');
    }

    toggle.addEventListener('click', () => panel.hidden ? openChat() : closeChat());
    closeBtn?.addEventListener('click', closeChat);

    function appendMsg(text, role) {
      const el = document.createElement('div');
      el.className = 'chat-widget__msg chat-widget__msg--' + role;
      el.textContent = text;
      messages.appendChild(el);
      messages.scrollTop = messages.scrollHeight;
    }

    function score(post, q) {
      const terms = q.toLowerCase().split(/\s+/).filter(Boolean);
      const hay = (post.title + ' ' + post.description + ' ' + (post.tags || []).join(' ') + ' ' + post.excerpt).toLowerCase();
      let s = 0;
      for (const t of terms) {
        if (hay.includes(t)) s += 1;
        if (post.title.toLowerCase().includes(t)) s += 2;
      }
      return s;
    }

    async function loadIndex() {
      if (knowledgeIndex) return knowledgeIndex;
      const res = await fetch('/knowledge-index.json');
      if (!res.ok) throw new Error('no index');
      const data = await res.json();
      knowledgeIndex = data.posts || [];
      return knowledgeIndex;
    }

    async function clientFallback(msg) {
      const posts = await loadIndex();
      const hits = posts
        .map(p => ({ post: p, s: score(p, msg) }))
        .filter(r => r.s > 0)
        .sort((a, b) => b.s - a.s)
        .slice(0, 4);
      if (!hits.length) {
        appendMsg('I could not find a matching post. Try /search or browse the homepage.', 'bot');
        return;
      }
      appendMsg('Here are posts that may help:', 'bot');
      const lines = hits.map(({ post }) => {
        const path = post.url.replace('https://hellodk.io', '') || '/' + post.slug;
        return post.title + '\n' + path;
      }).join('\n\n');
      appendMsg(lines, 'sources');
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const msg = input.value.trim();
      if (!msg) return;
      appendMsg(msg, 'user');
      input.value = '';
      input.disabled = true;

      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: msg }),
        });
        if (res.ok) {
          const data = await res.json();
          appendMsg(data.answer || data.error || 'No response', 'bot');
          if (data.sources?.length) {
            const links = data.sources.map(s => (s.url ? s.title + ': ' + s.url : s.title)).join('\n');
            appendMsg(links, 'sources');
          }
        } else {
          await clientFallback(msg);
        }
      } catch {
        try {
          await clientFallback(msg);
        } catch {
          appendMsg('Assistant unavailable. Try /search instead.', 'bot');
        }
      } finally {
        input.disabled = false;
        input.focus();
      }
    });
  })();
</script>

<style>
.chat-widget { position: fixed; bottom: 24px; right: 24px; z-index: 9999; font-family: system-ui, sans-serif; font-size: 0.875rem; }
.chat-widget__toggle {
  width: 52px; height: 52px; border-radius: 50%; border: none; cursor: pointer;
  background: #0066cc; color: #fff; box-shadow: 0 4px 16px rgba(0,0,0,0.25);
  display: flex; align-items: center; justify-content: center;
}
.chat-widget__toggle:hover { background: #0052a3; }
.chat-widget__panel {
  position: absolute; bottom: 64px; right: 0; width: 340px; max-width: calc(100vw - 48px);
  background: #fff; border: 1px solid #dee2e6; border-radius: 12px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.15); overflow: hidden;
  display: flex; flex-direction: column; max-height: 420px;
}
.chat-widget__header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 12px 14px; background: #15171a; color: #fff;
}
.chat-widget__header button { background: none; border: none; color: #fff; font-size: 1.4rem; cursor: pointer; line-height: 1; }
.chat-widget__messages { flex: 1; overflow-y: auto; padding: 12px; display: flex; flex-direction: column; gap: 8px; }
.chat-widget__hint { color: #6c757d; font-size: 0.8rem; margin: 0; }
.chat-widget__msg { padding: 8px 10px; border-radius: 8px; max-width: 90%; white-space: pre-wrap; word-break: break-word; }
.chat-widget__msg--user { align-self: flex-end; background: #e7f1ff; color: #1a1a1a; }
.chat-widget__msg--bot { align-self: flex-start; background: #f1f3f5; color: #1a1a1a; }
.chat-widget__msg--sources { align-self: flex-start; background: transparent; color: #0066cc; font-size: 0.75rem; padding: 0; }
.chat-widget__form { display: flex; gap: 6px; padding: 10px; border-top: 1px solid #dee2e6; }
.chat-widget__form input { flex: 1; padding: 8px 10px; border: 1px solid #dee2e6; border-radius: 6px; font-size: 0.875rem; }
.chat-widget__form button { padding: 8px 12px; background: #0066cc; color: #fff; border: none; border-radius: 6px; cursor: pointer; font-weight: 600; }
.chat-widget__form button:hover { background: #0052a3; }
</style>
