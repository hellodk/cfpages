---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
---

<BaseLayout title="404 — Page Not Found — hellodk.io">
  <div style="min-height:100vh;background:#15171a;">
    <Nav />
    <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:calc(100vh - 56px);text-align:center;padding:24px;">
      <p style="font-size:6rem;font-weight:900;color:#e5645e;line-height:1;font-family:var(--font-sans);">404</p>
      <h1 style="font-size:1.4rem;font-weight:700;color:#ffffff;margin:16px 0 8px;font-family:var(--font-sans);">Page not found</h1>
      <p style="color:#9eabb3;margin-bottom:28px;font-family:var(--font-sans);">The page you're looking for doesn't exist or has moved.</p>
      <div style="display:flex;gap:16px;flex-wrap:wrap;justify-content:center;font-family:var(--font-sans);">
        <a href="/" style="color:var(--color-accent);text-decoration:none;font-weight:600;">← Back to blog</a>
        <a href="/search" style="color:#9eabb3;text-decoration:none;font-weight:600;">Search →</a>
      </div>
    </div>
  </div>
</BaseLayout>
