---
import { getCollection } from 'astro:content';
import ChirpingLayout from '../../layouts/ChirpingLayout.astro';
import PostGrid from '../../components/PostGrid.astro';
import { toPost } from '../../utils/toPost';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const allTags = [...new Set(posts.flatMap(p => p.data.tags))];
  return allTags.map(tag => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter(p => p.data.tags.includes(tag))
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
        .map(toPost),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<ChirpingLayout title={`#${tag} — hellodk.io`} breadcrumb={`#${tag}`}>
  <header class="tag-head">
    <h1 class="tag-head__title">#{tag}</h1>
    <p class="tag-head__count">{posts.length} post{posts.length !== 1 ? 's' : ''}</p>
  </header>
  <PostGrid posts={posts} featureFirst={false} />
</ChirpingLayout>

<style>
.tag-head { margin-bottom: 8px; padding-bottom: 16px; border-bottom: 1px solid #dee2e6; }
.tag-head__title { font-family: var(--font-sans); font-size: 1.5rem; font-weight: 700; color: #e5645e; }
.tag-head__count { font-size: 0.82rem; color: #6c757d; margin-top: 4px; }
</style>
