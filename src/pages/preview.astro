---
// Theme comparison hub — standalone page, no site layout
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>hellodk.io — Theme Preview Hub</title>
  <style is:global>
    * { box-sizing: border-box; }
    body {
      font-family: system-ui, -apple-system, sans-serif;
      background: #0d1117;
      color: #e6edf3;
      margin: 0;
      padding: 48px 24px;
      line-height: 1.5;
    }
    h1 { font-size: 1.75rem; margin: 0 0 8px; }
    .sub { color: #8b949e; margin-bottom: 32px; }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 16px;
      max-width: 1000px;
    }
    .card {
      display: block;
      padding: 20px;
      border: 1px solid #30363d;
      border-radius: 12px;
      background: #161b22;
      color: inherit;
      text-decoration: none;
      transition: border-color 0.15s, transform 0.15s;
    }
    a.card:hover { border-color: #58a6ff; transform: translateY(-2px); }
    a.card--featured { border-color: #e5645e; }
    .card h2 { margin: 0 0 6px; font-size: 1.1rem; color: #58a6ff; }
    a.card--featured h2 { color: #e5645e; }
    .card .port { font-family: ui-monospace, monospace; font-size: 0.85rem; color: #3fb950; }
    .card p { margin: 8px 0 0; font-size: 0.875rem; color: #8b949e; }
    .badge {
      display: inline-block;
      font-size: 0.7rem;
      font-weight: 600;
      padding: 2px 8px;
      border-radius: 999px;
      margin-top: 10px;
    }
    .badge--jekyll { background: #2d1f1f; color: #e5645e; }
    .badge--astro { background: #e7f1ff; color: #0550ae; }
    .badge--legacy { background: #21262d; color: #8b949e; }
    footer { margin-top: 40px; font-size: 0.8rem; color: #6e7681; max-width: 1000px; }
    code { background: #21262d; padding: 2px 6px; border-radius: 4px; font-size: 0.85em; }
  </style>
</head>
<body>
  <h1>Theme preview hub</h1>
  <p class="sub">Run <code>npm run preview:all</code> if a port is down.</p>

  <div class="grid">
    <a class="card card--featured" href="http://127.0.0.1:4324/" target="_blank" rel="noopener">
      <h2>Vanilla Jasper2 (Jekyll)</h2>
      <div class="port">:4324</div>
      <p>Official jekyllt/jasper2 with your 21 blog posts.</p>
      <span class="badge badge--jekyll">Use this for Jasper2 look</span>
    </a>

    <a class="card" href="http://127.0.0.1:4321/" target="_blank" rel="noopener">
      <h2>Chirping Astro</h2>
      <div class="port">:4321</div>
      <p>Sidebar layout, search, Giscus, newsletter — with post thumbnails.</p>
      <span class="badge badge--astro">feat/chirping-astro</span>
    </a>

    <a class="card" href="http://127.0.0.1:4321/preview/visual" target="_blank" rel="noopener">
      <h2>Visual layout samples</h2>
      <div class="port">:4321</div>
      <p>Compare text-only vs thumbnail feed vs card grid.</p>
      <span class="badge badge--astro">New</span>
    </a>

    <a class="card" href="http://127.0.0.1:4322/" target="_blank" rel="noopener">
      <h2>Jasper2 Astro (rebuild)</h2>
      <div class="port">:4322</div>
      <p>Custom Astro reimplementation — not the official theme.</p>
      <span class="badge badge--astro">feat/jasper2</span>
    </a>

    <a class="card" href="http://127.0.0.1:4000/" target="_blank" rel="noopener">
      <h2>Legacy Jasper v1</h2>
      <div class="port">:4000</div>
      <p>Old biomadeira/jasper site (stale prebuild).</p>
      <span class="badge badge--legacy">Deprecated</span>
    </a>

    <a class="card" href="http://127.0.0.1:4323/" target="_blank" rel="noopener">
      <h2>Upstream Chirping starter</h2>
      <div class="port">:4323</div>
      <p>Official Chirping Astro template reference.</p>
      <span class="badge badge--astro">Template only</span>
    </a>
  </div>

  <footer>
    <strong>Vanilla Jasper2</strong> (:4324) is the real Jekyll theme.
    <strong>Jasper2 Astro</strong> (:4322) is a separate clone.
  </footer>
</body>
</html>
